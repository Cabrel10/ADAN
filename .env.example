# ADAN Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values.

# Binance API (required for live data fetching and paper trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_TESTNET=true

# Binance Testnet (optional, for paper trading on testnet)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key_here

# Trading parameters
TRADING_PAIR=BTC/USDT
INITIAL_BALANCE=25

# Dataset generation
ADAN_CANDLES=5000
