# Configuration d'environnement pour ADAN Trading Bot
# Copier ce fichier en .env et remplir les valeurs réelles

# Clés d'API Exchange (Binance, Kraken, etc.)
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here

# Configuration Telegram (optionnel - pour les alertes)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Niveau de log
LOG_LEVEL=INFO

# Mode de trading (paper ou live)
TRADING_MODE=paper

# Intervalle de monitoring (en secondes)
MONITOR_INTERVAL=60

# Nombre maximum de workers parallèles
MAX_WORKERS=4

# Timeout pour les requêtes API (en secondes)
API_TIMEOUT=30

# Répertoire de données (optionnel)
DATA_DIR=./data

# Répertoire de logs (optionnel)
LOG_DIR=./logs
